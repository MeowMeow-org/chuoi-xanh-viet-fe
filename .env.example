NEXT_PUBLIC_API_URL=""

# === VietMap ===
# Bật UI bản đồ ở client (server vẫn cần các *_API_KEY ở dưới).
NEXT_PUBLIC_VIETMAP_ENABLED="1"

# Key Tile (consumer có quyền API "Tile") — cho style/tile/sprite/glyph.
VIETMAP_TILE_API_KEY=""
# Key Geocode (consumer có quyền Auto Complete + Place + Geocode/Reverse + Route v3) — cho /api/vietmap/geocode, autocomplete, place, route.
VIETMAP_GEOCODE_API_KEY=""
# Tuỳ chọn: nếu chỉ có 1 key dùng chung, set ở đây (fallback cho cả 2 ở trên).
# VIETMAP_API_KEY=""

# Legacy — vẫn còn nhận làm fallback nhưng không khuyến khích (key sẽ lộ ra client).
# NEXT_PUBLIC_VIETMAP_API_KEY=""

# Worker VietMap GL (`public/vietmap-gl-csp-worker.js`) được copy khi `npm install`.

# Tuỳ chọn — Geocoding qua server (ưu tiên hơn NEXT_PUBLIC nếu set)
# GOOGLE_MAPS_SERVER_KEY=""
# Hoặc dùng chung (đã có sẵn cho bản đồ client): NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
# Bật thêm **Maps Embed API** trên cùng project nếu muốn chỉ đường nhúng iframe trên trang (vd. chi tiết sản phẩm).
# Nếu không có khóa Google, /api/geocode/search vẫn tra bằng OpenStreetMap.
